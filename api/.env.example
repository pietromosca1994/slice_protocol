# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── IOTA Network ──────────────────────────────────────────────────────────────
# testnet | mainnet | devnet | localnet
IOTA_NETWORK=testnet

# ── On-chain addresses (required) ─────────────────────────────────────────────
# Object ID of the shared SPVRegistry (spv package)
SPV_REGISTRY_ID=0x...

# Published package IDs
SPV_PACKAGE_ID=0x...

# ── Signer (required for write operations) ────────────────────────────────────
# Base64-encoded 32-byte Ed25519 private key
# Leave empty for read-only mode
ADMIN_SECRET_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Max gas budget per regular transaction (in IOTA MIST)
GAS_BUDGET=100000000
# Gas budget for package publish transactions (higher due to bytecode upload cost)
PUBLISH_GAS_BUDGET=2000000000
# RPC override (leave empty to use the default for IOTA_NETWORK)
IOTA_RPC_URL=
# Absolute path to the repo's packages/ directory.
# Leave empty when running locally (auto-detected). Set explicitly in Docker via Dockerfile ENV.
PACKAGES_PATH=
