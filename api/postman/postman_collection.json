{
  "info": {
    "name": "IOTA Securitization API",
    "description": "Complete collection for the IOTA Securitization Protocol REST API.\n\nSet the `baseUrl` variable to your server (default: http://localhost:3000).\nSet the `network` variable to `mainnet`, `testnet`, or `localnet`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "network", "value": "testnet", "type": "string" },
    { "key": "packageId", "value": "0xYOUR_PACKAGE_ID", "type": "string" },
    { "key": "poolStateId", "value": "0xPOOL_STATE_ID", "type": "string" },
    { "key": "complianceRegistryId", "value": "0xCOMPLIANCE_REGISTRY_ID", "type": "string" },
    { "key": "trancheRegistryId", "value": "0xTRANCHE_REGISTRY_ID", "type": "string" },
    { "key": "waterfallStateId", "value": "0xWATERFALL_STATE_ID", "type": "string" },
    { "key": "issuanceStateId", "value": "0xISSUANCE_STATE_ID", "type": "string" },
    { "key": "vaultId", "value": "0xVAULT_ID", "type": "string" },
    { "key": "coinType", "value": "0xPACKAGE::usdc::USDC", "type": "string" },
    { "key": "investorAddress", "value": "0xINVESTOR_ADDRESS", "type": "string" },
    { "key": "didObjectId", "value": "0xDID_OBJECT_ID", "type": "string" },
    { "key": "paymentCoinId", "value": "0xPAYMENT_COIN_OBJECT_ID", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Returns service status, default network, and configured package ID."
          }
        }
      ]
    },
    {
      "name": "Pool Contract",
      "item": [
        {
          "name": "Get Pool State",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Read the current on-chain PoolState object."
          }
        },
        {
          "name": "Set Contracts",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool/set-contracts?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool","set-contracts"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trancheFactory\": \"0xTRANCHE_FACTORY_ADDRESS\",\n  \"issuanceContract\": \"0xISSUANCE_CONTRACT_ADDRESS\",\n  \"waterfallEngine\": \"0xWATERFALL_ENGINE_ADDRESS\",\n  \"oracleAddress\": \"0xORACLE_ADDRESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Link downstream contract addresses. Requires AdminCap."
          }
        },
        {
          "name": "Initialise Pool",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool/initialise?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool","initialise"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poolId\": \"POOL-001\",\n  \"originator\": \"0xORIGINATOR_ADDRESS\",\n  \"spv\": \"0xSPV_ADDRESS\",\n  \"totalPoolValue\": \"10000000000\",\n  \"interestRate\": 500,\n  \"maturityDate\": \"1893456000000\",\n  \"assetHash\": \"abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Initialise pool with all foundational parameters. Requires AdminCap. interestRate is in basis points. maturityDate and totalPoolValue are u64 strings. assetHash is a 32-byte SHA-256 hex string."
          }
        },
        {
          "name": "Activate Pool",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool/activate?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool","activate"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Transition pool from Created → Active. Requires AdminCap."
          }
        },
        {
          "name": "Update Performance Data",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool/update-performance?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool","update-performance"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newOutstandingPrincipal\": \"9500000000\",\n  \"oracleTimestamp\": \"1700000000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Push updated repayment data from the oracle. Requires OracleCap."
          }
        },
        {
          "name": "Mark Default (Oracle)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool/mark-default/oracle?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool","mark-default","oracle"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Mark pool as Defaulted. Requires OracleCap."
          }
        },
        {
          "name": "Mark Default (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool/mark-default/admin?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool","mark-default","admin"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Mark pool as Defaulted. Requires AdminCap."
          }
        },
        {
          "name": "Close Pool",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pool/close?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","pool","close"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Finalise the pool. Requires AdminCap."
          }
        }
      ]
    },
    {
      "name": "Compliance Registry",
      "item": [
        {
          "name": "Get Registry State",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/compliance?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","compliance"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch transfer restrictions flag and default holding period."
          }
        },
        {
          "name": "Get Investor Record",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/compliance/investor/{{investorAddress}}?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","compliance","investor","{{investorAddress}}"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch a single investor's KYC record."
          }
        },
        {
          "name": "Set Transfer Restrictions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/compliance/restrictions?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","compliance","restrictions"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Toggle global transfer restrictions on/off. Requires ComplianceAdminCap."
          }
        },
        {
          "name": "Set Default Holding Period",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/compliance/default-holding-period?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","compliance","default-holding-period"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"holdingPeriodMs\": \"7776000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Set default lock-up in milliseconds (e.g. 7776000000 = 90 days). Requires ComplianceAdminCap."
          }
        },
        {
          "name": "Add Investor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/compliance/investors?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","compliance","investors"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"investor\": \"{{investorAddress}}\",\n  \"accreditationLevel\": 3,\n  \"jurisdiction\": \"US\",\n  \"didObjectId\": \"{{didObjectId}}\",\n  \"customHoldingMs\": \"0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Add a KYC-verified investor to the whitelist.\naccreditationLevel: 1=Retail, 2=Professional, 3=Institutional, 4=Qualified Purchaser.\nRequires ComplianceAdminCap."
          }
        },
        {
          "name": "Remove Investor",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/compliance/investors/{{investorAddress}}?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","compliance","investors","{{investorAddress}}"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Deactivate an investor (e.g. sanctions). Requires ComplianceAdminCap."
          }
        },
        {
          "name": "Update Accreditation",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/compliance/investors/{{investorAddress}}/accreditation?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","compliance","investors","{{investorAddress}}","accreditation"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newLevel\": 4\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Update an investor's accreditation level. Requires ComplianceAdminCap."
          }
        }
      ]
    },
    {
      "name": "Tranche Factory",
      "item": [
        {
          "name": "Get Tranche Registry",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch full TrancheRegistry state including supply caps and minted amounts."
          }
        },
        {
          "name": "Get Tranche Info — Senior (0)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/0?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","0"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch TrancheInfo for Senior tranche (type 0)."
          }
        },
        {
          "name": "Get Tranche Info — Mezz (1)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/1?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","1"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch TrancheInfo for Mezzanine tranche (type 1)."
          }
        },
        {
          "name": "Get Tranche Info — Junior (2)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/2?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","2"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch TrancheInfo for Junior tranche (type 2)."
          }
        },
        {
          "name": "Bootstrap",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/bootstrap?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","bootstrap"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seniorTreasuryId\": \"0xSENIOR_TREASURY_ID\",\n  \"mezzTreasuryId\": \"0xMEZZ_TREASURY_ID\",\n  \"juniorTreasuryId\": \"0xJUNIOR_TREASURY_ID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Extract TreasuryCaps from coin parking wrappers into the registry. Call once after deploy. Requires TrancheAdminCap."
          }
        },
        {
          "name": "Create Tranches",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/create?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","create"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seniorCap\": \"5000000000\",\n  \"mezzCap\": \"3000000000\",\n  \"juniorCap\": \"2000000000\",\n  \"issuanceContract\": \"0xISSUANCE_CONTRACT_ADDRESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Set supply caps and enable minting. Requires TrancheAdminCap."
          }
        },
        {
          "name": "Disable Minting",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/disable-minting?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","disable-minting"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Permanently disable minting. Requires TrancheAdminCap."
          }
        },
        {
          "name": "Melt Senior Tokens",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/melt/senior?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","melt","senior"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coinObjectId\": \"0xSENIOR_COIN_OBJECT_ID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Burn SENIOR_COIN tokens (melt)."
          }
        },
        {
          "name": "Melt Mezz Tokens",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/melt/mezz?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","melt","mezz"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coinObjectId\": \"0xMEZZ_COIN_OBJECT_ID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Burn MEZZ_COIN tokens (melt)."
          }
        },
        {
          "name": "Melt Junior Tokens",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tranches/melt/junior?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","tranches","melt","junior"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coinObjectId\": \"0xJUNIOR_COIN_OBJECT_ID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Burn JUNIOR_COIN tokens (melt)."
          }
        }
      ]
    },
    {
      "name": "Issuance Contract",
      "item": [
        {
          "name": "Get Issuance State",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/issuance/{{issuanceStateId}}?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","issuance","{{issuanceStateId}}"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Read IssuanceState: prices, window, total raised, vault balance."
          }
        },
        {
          "name": "Create Issuance State",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/issuance/create-state?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","issuance","create-state"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coinType\": \"{{coinType}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create and share a new IssuanceState object for a given stablecoin type. Requires IssuanceOwnerCap."
          }
        },
        {
          "name": "Start Issuance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/issuance/start?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","issuance","start"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issuanceStateId\": \"{{issuanceStateId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"saleStart\": \"1700000000000\",\n  \"saleEnd\": \"1702592000000\",\n  \"priceSenior\": \"1000000\",\n  \"priceMezz\": \"1000000\",\n  \"priceJunior\": \"1000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Open the subscription window. Timestamps in ms. Prices in stablecoin base units per token. Requires IssuanceOwnerCap."
          }
        },
        {
          "name": "End Issuance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/issuance/end?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","issuance","end"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issuanceStateId\": \"{{issuanceStateId}}\",\n  \"coinType\": \"{{coinType}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Close the subscription window. Requires IssuanceOwnerCap."
          }
        },
        {
          "name": "Invest",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/issuance/invest?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","issuance","invest"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issuanceStateId\": \"{{issuanceStateId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"trancheType\": 0,\n  \"paymentCoinId\": \"{{paymentCoinId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Subscribe to a tranche. trancheType: 0=Senior, 1=Mezz, 2=Junior. Investor must be KYC-whitelisted on-chain. paymentCoinId is the object ID of the investor's Coin<C> object."
          }
        },
        {
          "name": "Refund",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/issuance/refund?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","issuance","refund"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issuanceStateId\": \"{{issuanceStateId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"investor\": \"{{investorAddress}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Claim a refund after a cancelled issuance (succeeded=false)."
          }
        },
        {
          "name": "Release Funds to Vault",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/issuance/release-to-vault?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","issuance","release-to-vault"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issuanceStateId\": \"{{issuanceStateId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"vaultAddress\": \"{{vaultId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Release all raised funds to the PaymentVault after a successful issuance. Requires IssuanceOwnerCap."
          }
        }
      ]
    },
    {
      "name": "Payment Vault",
      "item": [
        {
          "name": "Get Vault Balance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/vault/{{vaultId}}?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","vault","{{vaultId}}"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch current vault balance, total deposited, and total distributed."
          }
        },
        {
          "name": "Create Vault",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vault/create?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","vault","create"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coinType\": \"{{coinType}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create and share a new VaultBalance object. Requires VaultAdminCap."
          }
        },
        {
          "name": "Authorise Depositor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vault/authorise-depositor?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","vault","authorise-depositor"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vaultId\": \"{{vaultId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"depositor\": \"0xDEPOSITOR_ADDRESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Grant deposit rights to an address. Requires VaultAdminCap."
          }
        },
        {
          "name": "Revoke Depositor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vault/revoke-depositor?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","vault","revoke-depositor"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vaultId\": \"{{vaultId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"depositor\": \"0xDEPOSITOR_ADDRESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Revoke deposit rights from an address. Requires VaultAdminCap."
          }
        },
        {
          "name": "Deposit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vault/deposit?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","vault","deposit"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vaultId\": \"{{vaultId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"coinObjectId\": \"0xCOIN_OBJECT_ID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Deposit a Coin<C> object into the vault. Caller must be an authorised depositor."
          }
        },
        {
          "name": "Release Funds",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vault/release?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","vault","release"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vaultId\": \"{{vaultId}}\",\n  \"coinType\": \"{{coinType}}\",\n  \"recipient\": \"0xRECIPIENT_ADDRESS\",\n  \"amount\": \"1000000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Release funds from vault to a recipient. Requires VaultAdminCap."
          }
        }
      ]
    },
    {
      "name": "Waterfall Engine",
      "item": [
        {
          "name": "Get Waterfall State",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "description": "Fetch full WaterfallState: outstanding principals, accrued interest, pending funds, mode."
          }
        },
        {
          "name": "Initialise Waterfall",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall/initialise?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall","initialise"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seniorOutstanding\": \"5000000000\",\n  \"mezzOutstanding\": \"3000000000\",\n  \"juniorOutstanding\": \"2000000000\",\n  \"seniorRateBps\": 300,\n  \"mezzRateBps\": 600,\n  \"juniorRateBps\": 1200,\n  \"paymentFrequency\": 0,\n  \"poolContractAddr\": \"0xPOOL_CONTRACT_ADDRESS\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Set per-tranche outstanding amounts and interest rates (in bps). paymentFrequency: 0=Monthly, 1=Quarterly. Requires WaterfallAdminCap."
          }
        },
        {
          "name": "Accrue Interest",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall/accrue-interest?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall","accrue-interest"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Accrue simple interest across all tranches based on elapsed time since last distribution."
          }
        },
        {
          "name": "Deposit Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall/deposit-payment?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall","deposit-payment"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"500000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Record an incoming pool repayment into pending funds."
          }
        },
        {
          "name": "Run Waterfall",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall/run?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall","run"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Execute full waterfall distribution over all pending funds (Normal / Turbo / Default mode)."
          }
        },
        {
          "name": "Trigger Turbo Mode",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall/turbo-mode?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall","turbo-mode"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Activate Turbo Mode — redirects all excess cash to Senior principal paydown. Requires WaterfallAdminCap."
          }
        },
        {
          "name": "Trigger Default Mode (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall/default-mode/admin?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall","default-mode","admin"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
            "description": "Activate Default Mode — all funds route to Senior recovery only. Requires WaterfallAdminCap."
          }
        },
        {
          "name": "Trigger Default Mode (Pool)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/waterfall/default-mode/pool?network={{network}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","waterfall","default-mode","pool"],
              "query": [{ "key": "network", "value": "{{network}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poolCapId\": \"0xPOOL_CAP_OBJECT_ID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Activate Default Mode via PoolCap (triggered by the PoolContract). Requires PoolCap object ID."
          }
        }
      ]
    }
  ]
}